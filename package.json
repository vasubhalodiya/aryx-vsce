{
  "name": "aryx-chat-ui",
  "displayName": "Aryx",
  "description": "React-based customizable chat-style VS Code sidebar UI",
  "version": "0.0.1",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "scripts": {
    "build:webview": ".\\node_modules\\@esbuild\\win32-x64\\esbuild.exe src/App.jsx --bundle --minify --format=iife --platform=browser --target=es2020 --loader:.svg=text --alias:@=./src --define:process.env.NODE_ENV='\"production\"' --outfile=dist/main.js",
    "build:settings": ".\\node_modules\\@esbuild\\win32-x64\\esbuild.exe src/pages/SettingsPage/SettingsPage.jsx --bundle --minify --format=iife --platform=browser --target=es2020 --loader:.svg=text --alias:@=./src --define:process.env.NODE_ENV='\"production\"' --outfile=dist/settings.js",
    "build": "npm run build:webview && npm run build:settings"
  },
  "contributes": {
    "commands": [
      {
        "command": "aryxChat.focus",
        "title": "Aryx: Focus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aryxChatContainer",
          "title": "Aryx",
          "icon": "media/aryx.svg"
        }
      ]
    },
    "views": {
      "aryxChatContainer": [
        {
          "id": "aryxChatView",
          "name": "Aryx",
          "type": "webview"
        }
      ]
    }
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "clsx": "^2.1.1",
    "lucide-react": "^0.552.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "tailwindcss": "^4.2.2"
  }
}
